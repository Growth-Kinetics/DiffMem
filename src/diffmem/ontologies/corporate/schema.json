{
  "name": "corporate",
  "version": "2.0",
  "description": "Company-grounded ontology for agency and corporate memory. Four entity types (people, external, projects, decisions) viewed through the lens of the root company entity. Commitments are demoted from a top-level type to in-file Open Items sections inside their owner. Structured metadata lives in YAML frontmatter with code-owned status enums.",
  "entity_types": [
    { "name": "people",    "folder": "entities/people",    "index_type": "human" },
    { "name": "external",  "folder": "entities/external",   "index_type": "company" },
    { "name": "projects",  "folder": "entities/projects",  "index_type": "project" },
    { "name": "decisions", "folder": "entities/decisions", "index_type": "decision" }
  ],
  "timeline_enabled": true,
  "user_entity_enabled": true,
  "contexts_folder": "entities/external",
  "followups_enabled": true,
  "followups_source": "open_items_sections",
  "status_enums": {
    "project":  ["proposed", "active", "paused", "completed", "cancelled"],
    "decision": ["proposed", "accepted", "rejected", "superseded"],
    "open_item": ["open", "in_progress", "blocked", "done", "cancelled"],
    "person":    ["active", "paused", "left"],
    "client":    ["active_client", "prospect", "vendor", "partner", "former"]
  },
  "frontmatter": {
    "required": ["type"],
    "common":   ["type", "title", "status", "timestamp"],
    "people":    ["affiliation", "allocation"],
    "external":  ["relationship_to_company", "revenue_weight", "primary_contact"],
    "projects":  ["owning_engagement", "company_priority"],
    "decisions": ["deciders", "date"]
  }
}
