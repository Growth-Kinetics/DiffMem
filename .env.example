# DiffMem configuration. Copy to .env and fill in values.
# Only OPENROUTER_API_KEY is required. Everything else has a sensible default.

# ============================================================
# REQUIRED
# ============================================================

# Your OpenRouter API key (https://openrouter.ai/keys).
# Used by the retrieval and writer agents.
OPENROUTER_API_KEY=

# ============================================================
# OPTIONAL
# ============================================================

# Shared default LLM for writer, onboarding, and retrieval agents.
DEFAULT_MODEL=

# Optional retrieval-only override. Leave empty to use DEFAULT_MODEL.
RETRIEVAL_MODEL=

# --- Authentication ---
# Leave REQUIRE_AUTH=false if DiffMem is behind a reverse proxy on a trusted
# network (the default Coolify setup). Set to true + provide API_KEY if you
# expose the service to the public internet.
REQUIRE_AUTH=false
API_KEY=

# --- CORS ---
# Comma-separated list of allowed origins. Default "*" is fine behind a
# reverse proxy; tighten if exposing directly.
ALLOWED_ORIGINS=*

# --- Backup (optional) ---
# BACKUP_BACKEND options:
#   none    -- default; rely on volume snapshots for durability
#   github  -- mirror each user's branch to a private GitHub repo
BACKUP_BACKEND=none

# Minutes between background backup runs. Set to 0 to disable.
BACKUP_INTERVAL_MINUTES=30

# GitHub backup credentials (only used when BACKUP_BACKEND=github).
# GITHUB_TOKEN needs `repo` scope on a private repo you own.
GITHUB_REPO_URL=
GITHUB_TOKEN=
